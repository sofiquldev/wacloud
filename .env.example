# =============================================================================
# WaCloud — environment templates
# =============================================================================
#
#  LOCAL DEV (Docker + Redis + bridge + MySQL):
#    cp .env.docker.example .env
#    docker compose up -d --build
#
#  PRODUCTION (Hostinger shared hosting — PHP only, no Redis/Node):
#    Use .env.hostinger.example as a guide; create .env on the server via hPanel/SSH.
#    Never upload your local Docker .env to Hostinger.
#
# =============================================================================

# Quick reference — Hostinger-safe defaults (see .env.hostinger.example for full file):
#   SESSION_DRIVER=file  CACHE_STORE=file  QUEUE_CONNECTION=sync
#   DB_HOST=127.0.0.1    REDIS_HOST=127.0.0.1    BRIDGE_URL=   (empty)

# Quick reference — Docker (see .env.docker.example for full file):
#   docker-compose.yml sets WACLOUD_DOCKER=true, REDIS_HOST=redis, BRIDGE_URL=http://bridge:3001
