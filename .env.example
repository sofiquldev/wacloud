APP_NAME=wacloud
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
# Use the real public URL in production (https://...) — required for correct asset URLs on shared hosting.
APP_URL=http://localhost:8080

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# Docker + MySQL: COMPOSE_PROFILES starts the `mysql` service on `docker compose up`.
#   docker compose up -d
#   (or explicitly: docker compose --profile mysql up -d)
COMPOSE_PROFILES=mysql
#   docker compose exec app php artisan migrate --force
#
# Inside the `app` container, DB_HOST must be the Compose service name `mysql`, not 127.0.0.1.
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=wacloud
DB_USERNAME=wacloud
DB_PASSWORD=secret
DB_ROOT_PASSWORD=rootsecret

# Optional: seconds to wait for MySQL on container start (docker-entrypoint.sh).
# MYSQL_WAIT_SECONDS=90

# SQLite (file only, no MySQL service): unset COMPOSE_PROFILES, then comment the block above and use:
# DB_CONNECTION=sqlite
# # DB_DATABASE is optional; Laravel uses database/database.sqlite
# # DB_SQLITE_JOURNAL_MODE=WAL

# cPanel / shared hosting MySQL (use 127.0.0.1, not "localhost", unless your host says otherwise):
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=your_db_name
# DB_USERNAME=your_db_user
# DB_PASSWORD=...

# File sessions + file cache keep traffic off the DB unless you switch to database/redis drivers.
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=true

# Wasabi / S3-compatible media storage (optional — falls back to local disk)
# FILESYSTEM_DISK=wasabi

# WaCloud WhatsApp bridge (internal Docker service)
BRIDGE_URL=http://bridge:3001
BRIDGE_SECRET=change-me-bridge-secret
WHATSAPP_SEND_DELAY_SECONDS=3
WHATSAPP_SEND_BURST_PER_MINUTE=20

VITE_APP_NAME="${APP_NAME}"
# Optional: Google OAuth client ID for Settings → backup to Google Drive (browser upload)
# VITE_GOOGLE_CLIENT_ID=

# Inertia SSR: enable only where you can run `php artisan inertia:start-ssr` (Node) alongside PHP.
# On typical shared hosting, keep these off and rely on Blade + SeoHead for SEO.
INERTIA_SSR_ENABLED=false
INERTIA_SSR_URL=http://127.0.0.1:13714
INERTIA_SSR_ENSURE_BUNDLE_EXISTS=false

# With compose profile `mysql`: host port for MySQL (optional)
# DB_PORT_FORWARD=33060
