# =============================================================================
# Local development with Docker — copy to .env for docker compose up
# =============================================================================
#   cp .env.docker.example .env
#   docker compose up -d --build
#   docker compose exec app php artisan migrate --force && docker compose exec app php artisan db:seed
# Compose overrides DB_HOST, Redis, queue, cache, and BRIDGE_URL — see docker-compose.yml
# =============================================================================

APP_NAME=wacloud
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

APP_TIMEZONE=UTC
LOG_LEVEL=debug

COMPOSE_PROFILES=mysql

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=wacloud
DB_USERNAME=wacloud
DB_PASSWORD=secret
DB_ROOT_PASSWORD=rootsecret

SESSION_DRIVER=file
FILESYSTEM_DISK=local

# Defaults below; docker-compose.yml forces redis + bridge for app/worker containers
QUEUE_CONNECTION=sync
CACHE_STORE=file
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

BRIDGE_URL=http://bridge:3001
BRIDGE_SECRET=change-me-bridge-secret
WHATSAPP_SEND_DELAY_SECONDS=3
WHATSAPP_SEND_BURST_PER_MINUTE=20

MAIL_MAILER=log
VITE_APP_NAME="${APP_NAME}"
INERTIA_SSR_ENABLED=false

APP_PORT=8080
DB_PORT_FORWARD=33060
