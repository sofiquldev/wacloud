# =============================================================================
# Hostinger / shared hosting — copy to .env ON THE SERVER only (never commit)
# =============================================================================
# PHP 8.2+, document root → Laravel public/
# After upload: composer install --no-dev, php artisan key:generate, migrate, storage:link
# =============================================================================

APP_NAME=wacloud
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://wa.dsoffice.org

APP_TIMEZONE=UTC
APP_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=warning

# MySQL from hPanel (prefer 127.0.0.1 over localhost)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=your_database
DB_USERNAME=your_user
DB_PASSWORD=your_password

# No Redis on shared hosting — file/sync only
SESSION_DRIVER=file
CACHE_STORE=file
QUEUE_CONNECTION=sync
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=hello@wa.dsoffice.org
MAIL_FROM_NAME="${APP_NAME}"

# WhatsApp bridge does NOT run on shared hosting.
# Leave empty, or set to a public VPS URL if you deploy services/whatsapp-bridge elsewhere.
BRIDGE_URL=
BRIDGE_SECRET=change-me-bridge-secret

# Optional: Wasabi/S3 for media (or use per-user filesystem in Settings)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_BUCKET=
# AWS_ENDPOINT=

VITE_APP_NAME="${APP_NAME}"
INERTIA_SSR_ENABLED=false

# Do NOT set these on Hostinger:
#   REDIS_HOST=redis
#   DB_HOST=mysql
#   BRIDGE_URL=http://bridge:3001
#   QUEUE_CONNECTION=redis
#   CACHE_STORE=redis
